<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="24sp"
            android:textColor="#4CAF50"
            android:typeface="monospace"
            android:paddingBottom="40dp" />

        <!-- Sound checkbox -->
        <CheckBox
            android:id="@+id/cb_sound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_sound"
            android:textSize="18sp"
            android:textColor="#00FF00"
            android:typeface="monospace" />

        <!-- Vibration checkbox -->
        <CheckBox
            android:id="@+id/cb_vibrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_vibrate"
            android:textSize="18sp"
            android:textColor="#00FF00"
            android:typeface="monospace" />

        <!-- Color scheme label -->
        <TextView
            android:id="@+id/tv_scheme_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_scheme"
            android:textSize="18sp"
            android:textColor="#00FF00"
            android:typeface="monospace"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <!-- Color scheme radio group -->
        <RadioGroup
            android:id="@+id/rg_color_scheme"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rb_scheme_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scheme_dark"
                android:textSize="16sp"
                android:textColor="#00FF00"
                android:typeface="monospace" />

            <RadioButton
                android:id="@+id/rb_scheme_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scheme_light"
                android:textSize="16sp"
                android:textColor="#00FF00"
                android:typeface="monospace" />

            <RadioButton
                android:id="@+id/rb_scheme_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scheme_high"
                android:textSize="16sp"
                android:textColor="#00FF00"
                android:typeface="monospace" />

        </RadioGroup>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Simulation button -->
        <Button
            android:id="@+id/btn_simulate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_simulate"
            android:textSize="18sp"
            android:textColor="#00FF00"
            android:backgroundTint="#1A00FF00"
            android:typeface="monospace"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Calibration reset button -->
        <Button
            android:id="@+id/btn_cal_reset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_cal_reset"
            android:textSize="18sp"
            android:textColor="#00FF00"
            android:backgroundTint="#1A00FF00"
            android:typeface="monospace"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Exit button -->
        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_exit"
            android:textSize="18sp"
            android:textColor="#00FF00"
            android:backgroundTint="#1A00FF00"
            android:typeface="monospace"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- Version & log path -->
        <TextView
            android:id="@+id/tv_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#1AFF00"
            android:typeface="monospace" />

    </LinearLayout>
</ScrollView>
